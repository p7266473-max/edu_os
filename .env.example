# ─────────────────────────────────────────────────────────────────────────────
# EduOS environment configuration
# Copy this file to .env and edit values before running docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── Timezone ──────────────────────────────────────────────────────────────────
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# ── Data directory (host path for persistent study materials) ─────────────────
# All uploads go here — visible in both EduOS and Webtop Desktop
CASAOS_DATA_DIR=~/casaos/eduos

# ── Webtop login credentials ──────────────────────────────────────────────────
WEBTOP_USER=edu_user
WEBTOP_PASSWORD=eduos2024
# ⚠ CHANGE THE PASSWORD before exposing this to the internet!
